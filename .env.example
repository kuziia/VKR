# Скопируй в .env и заполни. Файл .env не коммитится в git.

# ── Search pipeline (search/) ─────────────────────────────────────────────────
# Токен HuggingFace Hub — для загрузки датасетов и моделей.
# Без него публичные ресурсы жёстко рейт-лимитятся, закрытые не качаются.
HF_TOKEN=hf_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# LLM для Stage 06/07 QE (переопределяется флагом --llm-model)
# QE_LLM=Qwen/Qwen2.5-3B-Instruct

# gpu_memory_utilization vLLM (0..1), дефолт 0.70
# QE_VLLM_UTIL=0.85

# ── Webapp (webapp/) ──────────────────────────────────────────────────────────
# OAuth-токен Claude для LLM-агентов (summarize, rerank, interpret)
ANTHROPIC_OAUTH_TOKEN=

# Email для OpenAlex API («вежливый пул» — уменьшает рейт-лимит)
MAILTO=your@email.com

# Каталог локального кэша веб-приложения (таксономия, PDF)
CACHE_DIR=webapp_cache

# Строка подключения к БД-кэшу
DB_URL=sqlite+aiosqlite:///./webapp.db

# Модель эмбеддингов для семантического поиска
EMBEDDING_MODEL=intfloat/multilingual-e5-large

# Идентификатор снимка данных (опционально)
SNAPSHOT_ID=
